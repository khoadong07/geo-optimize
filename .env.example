# Used by docker-compose.yml to configure the Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geo_optimize
POSTGRES_PORT=5432

# Used by Prisma when run from the host (npx prisma migrate dev/studio).
# Inside docker-compose, the `app` service computes its own DATABASE_URL
# pointing at the `postgres` service by container name instead of this one.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geo_optimize?schema=public"

# Host port the `app` service is published on (container always listens on 3000)
APP_PORT=3000

OPENAI_API_KEY=""
GEMINI_API_KEY=""

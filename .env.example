# Used by docker-compose.yml to configure the Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geo_optimize
POSTGRES_PORT=5432

# Used by Prisma — must match the POSTGRES_* values above
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geo_optimize?schema=public"

OPENAI_API_KEY=""
GEMINI_API_KEY=""

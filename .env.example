OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Fallback used automatically when OPENAI_API_KEY / GEMINI_API_KEY above are
# empty — DeepInfra hosts both openai/gpt-oss-120b and google/gemini-2.5-flash
# behind a single OpenAI-compatible endpoint. Get a key at https://deepinfra.com
DEEPINFRA_API_KEY=""

# Auth (used to seed the initial admin user in MongoDB on first boot — see
# backend/src/auth/auth.service.ts). Required — the backend refuses to start
# without these set. Change AUTH_PASSWORD after first login.
AUTH_USERNAME=change-me
AUTH_PASSWORD=change-me
JWT_SECRET=generate-a-long-random-secret

# MongoDB root credentials (used by docker-compose.yml to enable auth on the
# mongo container). Required — generate your own, do not reuse examples.
MONGO_ROOT_USERNAME=change-me
MONGO_ROOT_PASSWORD=change-me
MONGODB_URI=mongodb://change-me:change-me@127.0.0.1:27017/geo-optimize?authSource=admin
MONGODB_URI_DOCKER=mongodb://change-me:change-me@mongo:27017/geo-optimize?authSource=admin

BACKEND_PORT=4000
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4000

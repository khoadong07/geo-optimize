// Module 1: Project Setup — Project, Brand, Prompt Set (with LLM paraphrase
// generation + human review), Platform Config, Target Config, Schedule Config.
//
// Out of scope for this schema: Run / Visibility Score / Sentiment / Citation
// tables (Module 2-3). Those will FK into PromptVersion.id (exact wording
// tested), ProjectPlatformConfig.id, TargetConfig.id, and ScheduleConfig.id.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// ENUMS
// =========================================================================

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum BrandAliasType {
  OFFICIAL
  VIETNAMESE
  ABBREVIATION
  OTHER
}

enum PromptIntent {
  DISCOVERY
  COMPARISON
  BRANDED
  LONG_TAIL
}

enum PromptLifecycleStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum SeedKeywordSource {
  SEARCH_CONSOLE
  MANUAL
  OTHER
}

enum LlmProvider {
  OPENAI
  GEMINI
  ANTHROPIC
  OTHER
}

enum GenerationBatchStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlatformName {
  GEMINI
  OPENAI
  PERPLEXITY
  GROK
  COPILOT
  GOOGLE_AI_OVERVIEW
}

enum TargetKind {
  POSITION
  APPEARANCE_RATE
  SENTIMENT
  SHARE_OF_VOICE
}

enum EvaluationWindowUnit {
  RUNS
  DAYS
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
}

enum PriorityTier {
  CORE
  STANDARD
  MAINTENANCE
}

enum TierChangeReason {
  INITIAL
  TARGET_MET_AUTO
  TARGET_REGRESSED_AUTO
  MANUAL_OVERRIDE
}

// =========================================================================
// PLACEHOLDER ACTOR MODEL
// Module 1 has no auth system yet; reviewedBy/createdBy/ownerId need a real
// identity, so this stands in until the real auth/user table exists — the
// FK shape on the other models won't need to change when it's swapped in.
// =========================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  ownedProjects         Project[]                  @relation("ProjectOwner")
  createdSeedKeywords   SeedKeyword[]              @relation("SeedKeywordCreatedBy")
  createdBatches        GenerationBatch[]          @relation("BatchCreatedBy")
  reviewedCandidates    GeneratedPromptCandidate[] @relation("CandidateReviewedBy")
  createdPromptVersions PromptVersion[]            @relation("PromptVersionCreatedBy")
  tierChanges           ScheduleTierHistory[]      @relation("TierChangedBy")
}

// =========================================================================
// PROJECT / BRAND / COMPETITORS
// =========================================================================

model Project {
  id              String        @id @default(cuid())
  ownerId         String?
  name            String
  industry        String?
  officialWebsite String?
  status          ProjectStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner           User?                   @relation("ProjectOwner", fields: [ownerId], references: [id])
  brandAliases    BrandAlias[]
  competitors     Competitor[]
  promptSets      PromptSet[]
  prompts         Prompt[]
  seedKeywords    SeedKeyword[]
  platformConfigs ProjectPlatformConfig[]
  targetConfigs   TargetConfig[]
  scheduleConfigs ScheduleConfig[]

  @@index([status])
}

// Name variants (Vietnamese name, abbreviation, English name) consumed
// downstream by future mention-detection/NLP matching against raw responses.
model BrandAlias {
  id        String         @id @default(cuid())
  projectId String
  alias     String
  type      BrandAliasType @default(OTHER)
  createdAt DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, alias])
}

model Competitor {
  id        String   @id @default(cuid())
  projectId String
  name      String
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comparisonPrompts Prompt[] @relation("PromptComparesToCompetitor")

  @@unique([projectId, name])
}

// =========================================================================
// PROMPT SET / GROUP / PROMPT / VERSION
// =========================================================================

// A named, versionable catalog of prompts within a project. Most projects
// will have exactly one ("Default"); multiple are supported (e.g. separate
// catalogs per product line/campaign).
model PromptSet {
  id          String   @id @default(cuid())
  projectId   String
  name        String   @default("Default")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptGroups PromptGroup[]
  prompts      Prompt[]

  @@unique([projectId, name])
}

// Sub-grouping inside a PromptSet, used so TargetConfig/ScheduleConfig can be
// assigned to a group of prompts instead of one prompt at a time
// (e.g. "Comparison prompts - Skincare").
model PromptGroup {
  id          String   @id @default(cuid())
  promptSetId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  promptSet      PromptSet       @relation(fields: [promptSetId], references: [id], onDelete: Cascade)
  prompts        Prompt[]
  targetConfigs  TargetConfig[]
  scheduleConfig ScheduleConfig?

  @@unique([promptSetId, name])
}

// Stable, logical "slot" for a tracked question. Text lives on PromptVersion;
// Prompt.id is the anchor that TargetConfig, ScheduleConfig, and the future
// Run table key off of, independent of wording edits. Never hard-deleted —
// lifecycle is tracked via `status`.
model Prompt {
  id                   String                @id @default(cuid())
  projectId            String
  promptSetId          String
  promptGroupId        String?
  intent               PromptIntent
  status               PromptLifecycleStatus @default(ACTIVE)
  comparedCompetitorId String?
  currentVersionId     String?               @unique
  deprecatedAt         DateTime?
  archivedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  project            Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  promptSet          PromptSet    @relation(fields: [promptSetId], references: [id], onDelete: Restrict)
  promptGroup        PromptGroup? @relation(fields: [promptGroupId], references: [id])
  comparedCompetitor Competitor?  @relation("PromptComparesToCompetitor", fields: [comparedCompetitorId], references: [id])

  // Pointer to the currently live wording (single source of truth for "what
  // runs now"). Creating a Prompt is a two-step transaction: insert Prompt
  // with currentVersionId = null, insert the first PromptVersion, then
  // update currentVersionId to point at it.
  currentVersion PromptVersion?  @relation("PromptCurrentVersion", fields: [currentVersionId], references: [id])
  versions       PromptVersion[] @relation("PromptVersionHistory")

  targetConfigs  TargetConfig[]
  scheduleConfig ScheduleConfig?

  @@index([projectId, status])
  @@index([promptSetId])
  @@index([promptGroupId])
}

// Immutable content snapshot. Never edited in place — an edit creates a new
// row and repoints Prompt.currentVersionId, so historical Run rows always
// resolve to the exact wording that was actually tested.
model PromptVersion {
  id                String   @id @default(cuid())
  promptId          String
  versionNumber     Int
  text              String   @db.Text
  sourceCandidateId String?  @unique
  createdAt         DateTime @default(now())
  createdById       String?

  prompt           Prompt                    @relation("PromptVersionHistory", fields: [promptId], references: [id], onDelete: Cascade)
  sourceCandidate  GeneratedPromptCandidate? @relation(fields: [sourceCandidateId], references: [id])
  createdBy        User?                     @relation("PromptVersionCreatedBy", fields: [createdById], references: [id])
  currentForPrompt Prompt?                   @relation("PromptCurrentVersion")

  @@unique([promptId, versionNumber])
}

// =========================================================================
// SEED KEYWORD -> LLM PARAPHRASE GENERATION -> HUMAN REVIEW
// =========================================================================

model SeedKeyword {
  id          String            @id @default(cuid())
  projectId   String
  text        String
  source      SeedKeywordSource @default(MANUAL)
  createdAt   DateTime          @default(now())
  createdById String?

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?             @relation("SeedKeywordCreatedBy", fields: [createdById], references: [id])
  batches   GenerationBatch[]

  @@unique([projectId, text])
}

// One LLM invocation against a single seed keyword, producing 5-10 candidate
// question variants.
model GenerationBatch {
  id                    String                @id @default(cuid())
  seedKeywordId         String
  provider              LlmProvider
  modelName             String
  generationPrompt      String                @db.Text
  requestedVariantCount Int                   @default(8)
  requestedIntents      PromptIntent[]
  status                GenerationBatchStatus @default(COMPLETED)
  createdAt             DateTime              @default(now())
  createdById           String?

  seedKeyword SeedKeyword                @relation(fields: [seedKeywordId], references: [id], onDelete: Cascade)
  createdBy   User?                      @relation("BatchCreatedBy", fields: [createdById], references: [id])
  candidates  GeneratedPromptCandidate[]

  @@index([seedKeywordId])
}

model GeneratedPromptCandidate {
  id                String       @id @default(cuid())
  generationBatchId String
  text              String       @db.Text
  suggestedIntent   PromptIntent
  reviewStatus      ReviewStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  editedText        String?      @db.Text
  rejectionReason   String?
  createdAt         DateTime     @default(now())

  generationBatch GenerationBatch @relation(fields: [generationBatchId], references: [id], onDelete: Cascade)
  reviewedBy      User?           @relation("CandidateReviewedBy", fields: [reviewedById], references: [id])
  promotedVersion PromptVersion?

  @@index([generationBatchId, reviewStatus])
}

// =========================================================================
// PLATFORM CONFIG
// Only enable/disable state + generic settings live here — API keys stay in
// environment variables (see .env.example), never in the database.
// =========================================================================

model ProjectPlatformConfig {
  id        String       @id @default(cuid())
  projectId String
  platform  PlatformName
  isEnabled Boolean      @default(false)
  config    Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, platform])
}

// =========================================================================
// TARGET CONFIG
// Attaches to exactly one of Prompt or PromptGroup (XOR). Prisma's schema
// language has no CHECK constraint syntax, so this invariant is enforced by
// a hand-added Postgres CHECK constraint after the first migration (see
// prisma/migrations/*/migration.sql) plus app-layer validation.
// =========================================================================

model TargetConfig {
  id             String               @id @default(cuid())
  projectId      String
  promptId       String?
  promptGroupId  String?
  kind           TargetKind
  // Interpretation of thresholdValue depends on `kind`:
  //   POSITION         -> max acceptable rank / "top N" (e.g. 3.00 = top 3)
  //   APPEARANCE_RATE  -> minimum percentage of runs brand must appear in
  //   SENTIMENT        -> minimum percentage of appearances that must be positive
  //   SHARE_OF_VOICE   -> minimum percentage share of all brand mentions in category
  thresholdValue Decimal              @db.Decimal(6, 2)
  windowUnit     EvaluationWindowUnit
  windowValue    Int
  minSampleSize  Int?
  extraParams    Json?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt      Prompt?      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptGroup PromptGroup? @relation(fields: [promptGroupId], references: [id], onDelete: Cascade)

  @@unique([promptId, kind])
  @@unique([promptGroupId, kind])
  @@index([projectId, kind])
}

// =========================================================================
// SCHEDULE CONFIG
// Same XOR scoping pattern as TargetConfig: a schedule can be set on a
// specific Prompt (override) or on a PromptGroup (default for its members).
// =========================================================================

model ScheduleConfig {
  id                String            @id @default(cuid())
  projectId         String
  promptId          String?           @unique
  promptGroupId     String?           @unique
  frequency         ScheduleFrequency
  runsPerCycle      Int               @default(1)
  priorityTier      PriorityTier      @default(STANDARD)
  isAutoMaintenance Boolean           @default(true)
  isPaused          Boolean           @default(false)
  lastTierChangeAt  DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prompt      Prompt?               @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptGroup PromptGroup?          @relation(fields: [promptGroupId], references: [id], onDelete: Cascade)
  tierHistory ScheduleTierHistory[]

  @@index([projectId, priorityTier])
}

// Audit trail of tier transitions (e.g. STANDARD -> MAINTENANCE because
// target was met; MAINTENANCE -> STANDARD because it regressed).
model ScheduleTierHistory {
  id               String           @id @default(cuid())
  scheduleConfigId String
  fromTier         PriorityTier?
  toTier           PriorityTier
  reason           TierChangeReason
  changedAt        DateTime         @default(now())
  changedById      String?

  scheduleConfig ScheduleConfig @relation(fields: [scheduleConfigId], references: [id], onDelete: Cascade)
  changedBy      User?          @relation("TierChangedBy", fields: [changedById], references: [id])

  @@index([scheduleConfigId, changedAt])
}
